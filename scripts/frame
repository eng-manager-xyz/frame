#!/usr/bin/env bash
set -euo pipefail

ROOT=$(cd "$(dirname "$0")/.." && pwd)
cd "$ROOT"

WRANGLER_VERSION=4.111.0
LOCAL_CONFIG=apps/control-plane/wrangler.local.toml
LOCAL_DB=frame-local
LOCAL_STATE=apps/control-plane/.wrangler/state
PID_FILE=.tmp/frame-local.pids
MEDIA_ADDR=${FRAME_MEDIA_ADDR:-127.0.0.1:8790}
GSTREAMER_EXEC="$ROOT/scripts/ci/gstreamer-sanitized-exec"
MACOS_APP="$ROOT/target/release/bundle/macos/Frame.app"
MACOS_SIGNER="$ROOT/scripts/ci/sign-macos-local-app.sh"

# `scripts/frame` is a trusted local/service entrypoint. Clear native loader
# overrides before invoking any child process; raw binaries also reject these
# variables for fail-closed diagnostics.
unset LD_LIBRARY_PATH LD_PRELOAD LD_AUDIT
unset DYLD_LIBRARY_PATH DYLD_FALLBACK_LIBRARY_PATH DYLD_INSERT_LIBRARIES
unset DYLD_FRAMEWORK_PATH DYLD_FALLBACK_FRAMEWORK_PATH DYLD_ROOT_PATH
unset DYLD_IMAGE_SUFFIX DYLD_SHARED_REGION

usage() {
  cat <<'EOF'
Usage: scripts/frame <command>

  doctor       verify the local Rust, Wasm, GStreamer, Node, and migration tools
  check        run formatting, Clippy, Wasm, boundary, fixture, and migration gates
  test         run the complete workspace test suite
  migrate      apply all D1 migrations to the isolated local database
  seed         load deterministic synthetic local data
  reset        remove only local Wrangler state, then migrate and seed
  start        run the web, Worker, and native media doctor until interrupted
  stop         stop processes started by scripts/frame start
  logs         tail the local web and Worker logs
  media-smoke  create a synthetic WebM artifact under target/
  desktop-macos-bundle
               build and sign the local release-mode Frame.app
  desktop-macos-sign
               re-sign and verify the existing local Frame.app
  desktop-macos-open
               verify and launch the existing signed Frame.app
  desktop-macos-identities
               list installed Apple code-signing identities
  d1-conformance
                run aggregate repository parity/fault tests in isolated local D1
  preview-e2e   run the credential-free two-origin portfolio/Frame journey
EOF
}

require_macos() {
  if [[ $(uname -s) != Darwin ]]; then
    printf 'this command requires macOS\n' >&2
    exit 2
  fi
}

build_macos_app() {
  require_macos
  need cargo
  need python3
  python3 scripts/ci/build-desktop-ui.py
  python3 scripts/ci/check-desktop-bundle.py
  (
    cd apps/desktop
    cargo tauri build --bundles app \
      --features macos-native,custom-protocol
  )
  "$MACOS_SIGNER" sign
}

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'missing required tool: %s\n' "$1" >&2
    return 1
  fi
}

configure_gstreamer() {
  need pkg-config
  local plugin_dir
  plugin_dir=$(pkg-config --variable=pluginsdir gstreamer-1.0)
  if [[ -z $plugin_dir || ! -d $plugin_dir ]]; then
    printf 'pkg-config did not return an installed GStreamer plugin directory\n' >&2
    return 1
  fi
  export GST_PLUGIN_SYSTEM_PATH_1_0=$plugin_dir
}

check_macos_native_desktop() {
  if [[ $(uname -s) != Darwin ]]; then
    return 0
  fi
  "$GSTREAMER_EXEC" cargo clippy --locked -p frame-desktop-core \
    --features macos-native,custom-protocol --all-targets -- -D warnings
}

test_macos_native_desktop() {
  if [[ $(uname -s) != Darwin ]]; then
    return 0
  fi
  "$GSTREAMER_EXEC" cargo test --locked -p frame-desktop-core \
    --features macos-native,custom-protocol
}

refuse_production() {
  if [[ ${FRAME_DEPLOYMENT:-local} == production ]] ||
    [[ -n ${CLOUDFLARE_API_TOKEN:-} ]] ||
    [[ -n ${DATABASE_URL:-} ]]; then
    printf 'local command refused while production/provider credentials are present\n' >&2
    exit 2
  fi
}

doctor() {
  local failed=0
  for tool in cargo cargo-deny worker-build rustc rustup python3 node npx pkg-config; do
    need "$tool" || failed=1
  done
  if [[ $failed -ne 0 ]]; then
    return 1
  fi

  rustc --version
  cargo --version
  node --version
  if [[ $(cargo-deny --version) != "cargo-deny 0.20.2" ]]; then
    printf 'cargo-deny 0.20.2 is required (install with --version 0.20.2 --locked)\n' >&2
    failed=1
  fi
  if [[ $(worker-build --version) != "0.8.5" ]]; then
    printf 'worker-build 0.8.5 is required (install with --version 0.8.5 --locked)\n' >&2
    failed=1
  fi
  if ! rustup target list --installed | rg -qx 'wasm32-unknown-unknown'; then
    printf 'missing Rust target: rustup target add wasm32-unknown-unknown\n' >&2
    failed=1
  fi
  if ! pkg-config --atleast-version=1.22 gstreamer-1.0; then
    printf 'GStreamer 1.22+ development/runtime files are required\n' >&2
    failed=1
  fi
  python3 scripts/ci/check-migrations.py || failed=1
  "$GSTREAMER_EXEC" cargo run --quiet -p frame-media-worker -- doctor || failed=1
  python3 scripts/ci/check-local-prerequisites.py --ports 3000 8787 8790 || failed=1
  npx --yes "wrangler@${WRANGLER_VERSION}" --version || failed=1
  return "$failed"
}

migrate() {
  refuse_production
  npx --yes "wrangler@${WRANGLER_VERSION}" d1 migrations apply "$LOCAL_DB" \
    --local --config "$LOCAL_CONFIG"
}

seed() {
  refuse_production
  npx --yes "wrangler@${WRANGLER_VERSION}" d1 execute "$LOCAL_DB" \
    --local --config "$LOCAL_CONFIG" --file dev/seed.sql
}

stop_local() {
  if [[ ! -f $PID_FILE ]]; then
    printf 'local Frame processes are not recorded as running\n'
    return 0
  fi
  while IFS= read -r pid; do
    if [[ $pid =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid"
    fi
  done < "$PID_FILE"
  rm -f "$PID_FILE"
}

start_local() {
  refuse_production
  mkdir -p .tmp
  stop_local >/dev/null
  : > "$PID_FILE"

  migrate
  seed

  cargo run -p frame-web > .tmp/frame-web.log 2>&1 &
  printf '%s\n' "$!" >> "$PID_FILE"
  npx --yes "wrangler@${WRANGLER_VERSION}" dev --config "$LOCAL_CONFIG" \
    --port 8787 > .tmp/frame-worker.log 2>&1 &
  printf '%s\n' "$!" >> "$PID_FILE"

  FRAME_MEDIA_ADDR="$MEDIA_ADDR" "$GSTREAMER_EXEC" cargo run -p frame-media-worker -- serve \
    > .tmp/frame-media-worker.log 2>&1 &
  printf '%s\n' "$!" >> "$PID_FILE"

  trap 'stop_local' EXIT INT TERM
  printf 'Frame local web: http://127.0.0.1:3000\n'
  printf 'Frame local API: http://127.0.0.1:8787/api/v1/health\n'
  printf 'Frame native media: http://%s/health/ready\n' "$MEDIA_ADDR"
  printf 'Press Ctrl-C to stop.\n'
  wait
}

command=${1:-}
case "$command" in
  doctor)
    configure_gstreamer
    doctor
    ;;
  check)
    configure_gstreamer
    cargo fmt --all --check
    "$GSTREAMER_EXEC" cargo clippy --workspace --all-targets -- -D warnings
    "$GSTREAMER_EXEC" cargo clippy --locked -p frame-desktop-core --features instant-finalize --all-targets -- -D warnings
    check_macos_native_desktop
    cargo deny check advisories bans licenses sources
    scripts/ci/check-workspace-boundaries.sh
    python3 scripts/ci/check-secrets.py
    python3 scripts/ci/generate-cyclonedx.py --self-test
    python3 -I scripts/ci/hermetic-journey.py --timeout 20
    python3 scripts/ci/check-fixtures.py
    python3 -I scripts/ci/check-issue-closure.py
    python3 -I scripts/ci/check-desktop-product.py
    python3 -I scripts/ci/check-media-service.py
    python3 -I scripts/ci/run-legacy-api-parity.py \
      --evidence-dir target/evidence
    python3 scripts/ci/check-cloudflare-zone-contract.py
    python3 -I scripts/ci/check-cloudflare-edge-policy.py
    python3 -I scripts/ci/test-frame-cache-purge.py
    python3 -I scripts/ci/check-browser-security.py
    python3 -I scripts/ci/check-share-player.py \
      --evidence target/evidence/share-player-local.json
    python3 -I scripts/ci/check-engmanager-portfolio-integration.py
    python3 -I scripts/ci/check-launch-observability.py
    python3 scripts/ci/test-migration.py
    python3 scripts/ci/cutover-authority-conformance.py
    python3 -I scripts/ci/business-sqlite-semantic-conformance.py
    python3 -I scripts/ci/organization-sqlite-semantic-conformance.py
    python3 -I scripts/ci/public-collaboration-sqlite-conformance.py
    python3 -I scripts/ci/direct-upload-sqlite-conformance.py
    python3 -I scripts/ci/r2-completion-reconciliation-sqlite-conformance.py
    python3 -I scripts/ci/instant-finalize-sqlite-conformance.py
    python3 -I scripts/ci/media-job-inputs-sqlite-conformance.py
    python3 -I scripts/ci/worker-auth-sqlite-conformance.py
    python3 -I scripts/migration/test_cap_id_map.py
    python3 -I scripts/migration/test_etl_cap_id_map.py
    python3 -I scripts/migration/test_cap_business_plan_contract.py
    python3 -I scripts/migration/test_local.py
    python3 -I scripts/migration/test_mysql_snapshot.py
    python3 -I scripts/migration/test_mysql_cdc.py
    python3 -I scripts/migration/test_d1_target.py
    ;;
  test)
    configure_gstreamer
    "$GSTREAMER_EXEC" cargo test --workspace
    "$GSTREAMER_EXEC" cargo test --locked -p frame-desktop-core --features instant-finalize
    test_macos_native_desktop
    python3 -I scripts/ci/run-legacy-api-parity.py \
      --evidence-dir target/evidence
    python3 -I scripts/ci/r2-completion-reconciliation-sqlite-conformance.py
    python3 -I scripts/ci/worker-auth-sqlite-conformance.py
    ;;
  migrate)
    migrate
    ;;
  seed)
    seed
    ;;
  reset)
    refuse_production
    if [[ -d $LOCAL_STATE ]]; then
      rm -rf "$LOCAL_STATE"
    fi
    migrate
    seed
    ;;
  start)
    configure_gstreamer
    start_local
    ;;
  stop)
    stop_local
    ;;
  logs)
    mkdir -p .tmp
    touch .tmp/frame-web.log .tmp/frame-worker.log .tmp/frame-media-worker.log
    tail -n 100 -f .tmp/frame-web.log .tmp/frame-worker.log .tmp/frame-media-worker.log
    ;;
  media-smoke)
    configure_gstreamer
    "$GSTREAMER_EXEC" cargo run -p frame-media-worker -- smoke target/frame-smoke.webm
    ;;
  desktop-macos-bundle)
    configure_gstreamer
    build_macos_app
    ;;
  desktop-macos-sign)
    require_macos
    "$MACOS_SIGNER" sign
    ;;
  desktop-macos-open)
    require_macos
    "$MACOS_SIGNER" verify
    open "$MACOS_APP"
    ;;
  desktop-macos-identities)
    require_macos
    "$MACOS_SIGNER" identities
    ;;
  d1-conformance)
    refuse_production
    python3 -I scripts/ci/d1-repository-conformance.py
    python3 -I scripts/ci/auth-d1-conformance.py
    python3 -I scripts/ci/organization-d1-conformance.py
    python3 -I scripts/ci/api-workflow-d1-conformance.py
    ;;
  preview-e2e)
    refuse_production
    python3 -I scripts/ci/cross-repo-preview-e2e.py --self-test --timeout 20
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
