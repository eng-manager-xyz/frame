# Safe local-only defaults. `scripts/frame` does not source this file implicitly.
FRAME_DEPLOYMENT=local
FRAME_ADDR=127.0.0.1:3000
FRAME_MEDIA_ADDR=127.0.0.1:8790
FRAME_MEDIA_MODE=fake
FRAME_PUBLIC_HOST=localhost

