{
  "identifier": "frame-desktop-windows",
  "description": "Minimal core event and window controls for Frame desktop surfaces.",
  "local": true,
  "windows": [
    "main",
    "recorder-*",
    "recovery-*",
    "editor-*",
    "export-*"
  ],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-close",
    "core:window:allow-set-focus"
  ],
  "platforms": [
    "linux",
    "macOS",
    "windows"
  ]
}
