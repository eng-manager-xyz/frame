  "release_rule": "A durable D1 intent or dequeued outbox is never provider success. A legacy success may be projected only by resolving an opaque sealed terminal bound to immutable independent_provider_executor evidence for the same request digest.",
  "security": {
    "authorization": "D1 resolves legacy organization, space, and video identifiers to native resources and re-authorizes exact credential kind/subject/key-version/digest/expiry, policy proofs, entitlement revision/expiry, conditional bindings, the owning organization owner's exact user revision, and the separately digested cross-family parent authority at insert, replay, and evidence admission.",
    "tenant_non_disclosure": "Cross-tenant and absent protected resources collapse to the same forbidden/not-found family selected by the carrier.",
    "secret_storage": "Plaintext credentials, OAuth codes/tokens, signed URLs, email addresses, feedback, logs, provider JSON, response bodies, and cookies never enter D1. A server-owned narrow vault returns randomized frame-pi-request-v1 opaque references plus deterministic plaintext digests; verified output is stored only as a frame-pi-terminal-v1 opaque reference plus digest.",
    "replay": "Released Cap callers never require an invented Idempotency-Key. Ordinary routes, RPCs, and actions use atomic principal-bound request-digest claims with pending reachability and bounded terminal retention; signed webhook deliveries and Loom workflows use server-derived natural identities.",
    "provider_failure": "Pending, dead-lettered, corrupt, unavailable, and executor-lease-mismatched provider states fail closed and never return a legacy success shape.",
    "webhooks": "The carrier verifies the configured media-server secret in constant time, binds natural replay to the exact transport-body digest, and persists no raw credential or body.",
    "source_compatibility": "Desktop withAuth carriers accept exact session or 36-character API-key branches; logs also permits anonymous access; Google OAuth exchange requires verified expiring signed state; public Loom/release/email carriers do not mint sessions; the Loom domain workflow resolves loom.orgId through the canonical organization domain; getVideoStatus represents optional session and independent password policy proofs.",
    "conditional_authority": {
      "space_create_actor_pro": ["passwordEnabled", "disableSummary", "disableChapters", "disableTranscript"],
      "space_publish_owner_pro": "The owning organization's exact owner user and user-authority revision must remain Pro; an authorized organization or space manager need not be that owner.",
      "space_update_non_pro_settings": "A non-Pro manager preserves existing Pro viewer settings, so submitted viewer flags do not create an update-time Pro gate.",
      "seat_capacity": "proSeatsUsed counts each active hasProSeat member once and also counts the active Pro owner's membership once when hasProSeat is false."
    },
    "workflow_authority": {
      "loom_domain_identity": "LoomImportVideo binds cap.userId to the inherited native actor through legacy_collaboration_user_aliases_v1 and binds both cap.orgId and loom.orgId to the inherited native tenant through legacy_user_account_organization_ids_v1.",
      "loom_media_identity": "importLoomVideoWorkflow binds payload userId to the target video's native owner through the legacy user alias. Direct imports require that owner to be the parent actor; CSV imports allow the selected active organization member to own the video.",
      "raw_file_key": {
        "initial": "Direct and CSV launches require {legacy_user_id}/{legacy_video_id}/raw-upload.mp4.",
        "retry": "A retry-processing parent requires the exact live legacy_mobile_cap_uploads_v1.raw_file_key for the same target video."
      },
      "empty_retry_url": "loomDownloadUrl is a required string shape but may be empty because the pinned retry launcher sends an empty string and the workflow does not read it.",
      "parent_scoped_replay": "importLoomVideoWorkflow natural replay includes the exact parent family, receipt, and request digest, so one parent is idempotent while a newly admitted retry parent can launch a new run."
    },
    "natural_replay": {
      "scope": "Natural identities are globally unique per source operation and replay digest, independent of principal or credential rotation; generated replay remains principal-bound.",
      "signed_webhook": "The exact transport-body digest remains unique across signed-endpoint key rotation.",
      "loom_domain_workflow": "The source payload idempotency key remains unique across session or API-key rotation."
    },
    "loom_download_egress": {
      "payload_pointer": "/loom/video/downloadUrl",
      "scheme": "https",
      "host_policy": "loom.com or a subdomain of loom.com; IP literals, localhost aliases, user-info, fragments, and explicit ports are rejected.",
      "redirect_policy": "The executor must reject redirects unless every hop is revalidated by the same policy.",
      "dns_policy": "The executor must reject loopback, link-local, private, multicast, unspecified, and otherwise non-public resolved addresses for every connection."
    },
