  "authentication": {
    "sdk": "authorization split on one literal space at index one; cpk_ prefix; keyed digest lookup; active public key and live app required",
    "sdk_production_origin": "Origin is required and must exactly equal an app domain; development apps do not require Origin",
    "rest": "authorization split on one literal space at index one; csk_ prefix; keyed digest lookup; active secret key and live app required",
    "cron": "CRON_SECRET must exist and Authorization must constant-time match Bearer plus the secret",
    "last_used_debounce_ms": 300000,
    "rate_limit": "60 requests per 60-second edge source window",
    "cors": {
      "allow_origin": "*",
      "credentials": false,
      "allow_methods": "GET, POST, OPTIONS",
      "allow_headers": "Content-Type, Authorization"
    }
  },
  "wire_contracts": {
    "video_create": {
      "optional": ["name", "userId", "metadata"],
      "name_and_user_utf16_max": 255,
      "metadata_json_utf16_max": 8192,
      "default_name": "Untitled",
      "object_key": "developer/{legacyAppId}/{legacyVideoId}/video",
      "response": "{videoId,s3Key,shareUrl,embedUrl}"
    },
    "multipart": {
      "content_types": [
        "video/mp4",
        "video/webm",
        "video/quicktime",
        "video/x-matroska",
        "video/avi",
        "application/octet-stream"
      ],
      "unknown_content_type": "defaults_to_video_mp4",
      "part_number": "integer_1_through_10000",
      "presigned_put_headers": "none",
      "presigned_url_ttl_seconds": 900,
      "complete_parts": "sorted_by_partNumber_before_R2_complete",
      "durationInSecs": "required_positive_finite_then_clamped_to_four_hours"
    },
    "usage": "{data:{balanceMicroCredits,balanceDollars,totalVideos,totalDurationMinutes}}",
    "videos_list": "{data:[video]} ordered createdAt descending; userId exact filter; default limit 50, maximum 100; nonnegative offset",
    "video_get": "{data:video}; deleted, foreign, and absent all return Video not found",
    "video_status": "{data:{id,duration,width,height,transcriptionStatus,ready}} where ready requires duration and width",
    "video_delete": "soft tombstone and {success:true}",
    "cron": "{success:true,date,appsProcessed} using the UTC YYYY-MM-DD snapshot day"
  },
  "billing": {
    "create_minimum_balance_microcredits": 5000,
    "completion_microcredits_per_minute": 5000,
    "completion_max_duration_seconds": 14400,
    "completion_size_floor_bytes_per_second": 2500000,
    "completion_formula": "floor(min(14400,max(min(durationInSecs,14400),sum(part.size)/2500000))/60*5000)",
    "daily_storage_microcredits_per_minute": "3.33",
    "daily_storage_formula": "floor(total_live_duration_minutes*333/100)",
    "zero_charge_or_no_account": "skip",
    "insufficient_balance": "atomic debit is rejected and app is not counted processed"
  },
  "idempotency": {
    "released_sdk_sends_header": false,
    "mutations": "optional supplied header is durable; absent header receives a unique server execution key",
    "same_key_same_request": "replay immutable receipt",
    "same_key_different_request": "409 Idempotency conflict",
    "reads": "forbidden",
    "provider_effects": "D1 effect_pending outbox claims before R2 create, complete, or abort; complete and abort resume; an unbound create fails closed"
  },
