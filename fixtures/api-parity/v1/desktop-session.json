  "query_contract": {
    "port": "optional decimal TCP port 1..65535; Frame security tightening rejects Cap's unconstrained string",
    "platform": "web|desktop; default web",
    "type": "session|api_key; default session",
    "unknown_or_duplicate_fields": "400 Bad Request"
  },
  "wire_contract": {
    "unauthenticated_or_invalid_session": {
      "status": 302,
      "location": "<deployment-origin>/login?next=<absolute original request URL>",
      "cache_control": "no-store"
    },
    "session": {
      "credential": "the already-authenticated __Host-frame_session cookie",
      "expires": "minimum durable idle/absolute expiry as Unix seconds",
      "params": "type=token&token=<raw>&expires=<seconds>&user_id=<actor>"
    },
    "api_key": {
      "credential": "random UUID v4 returned once; D1 retains SHA-256 digest only",
      "source": "desktop",
      "params": "type=api_key&api_key=<uuid>&user_id=<actor>"
    },
    "web_with_port": {
      "status": 302,
      "location": "http://127.0.0.1:<validated-port>?<params>"
    },
    "desktop_with_port": {
      "status": 200,
      "content_type": "text/html; charset=utf-8",
      "behavior": "escaped JSON state opens cap-desktop://signin first and loopback fallback after 1800ms",
      "headers": "no-store, no-referrer, nosniff, restrictive CSP"
    },
    "without_port": {
      "status": 302,
      "location": "cap-desktop://signin?<params>"
    },
    "failure": {
      "bad_query": 400,
      "D1_or_auth_infrastructure": 500
    },
    "cors": {
      "allowed_origins": "configured web origin plus localhost:3000, localhost:3001, and three Tauri origins",
      "credentials": true,
      "methods": "GET, POST, PATCH, DELETE, OPTIONS",
      "headers": "Content-Type, Authorization, sentry-trace, baggage"
    }
  },
  "authority": {
    "session": "AuthService verifies the host-only cookie against D1 auth_sessions_v2 and returns only its matching session expiry",
    "key_mint": "single D1 INSERT SELECT active actor RETURNING exact row; digest-only auth_api_keys storage",
    "tenant_scope": "actor-owned identity credential; no request-controlled user id",
    "provider_calls": "none"
  },
