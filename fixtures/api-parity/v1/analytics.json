  "video_authority": {
    "failure_disclosure": "not_found",
    "resolution": ["native_video_id", "legacy_collaboration_video_aliases_v1"],
    "owner_bypass": true,
    "shared_membership": ["active_organization_share", "space_membership"],
    "public_requirements": ["legacy_public", "verified_allowed_email_domain_if_configured"],
    "password_rule": "A video or containing space password requires an unexpired D1 grant for everyone except the owner, including organization and space members.",
    "caller_authorized_boolean_trusted": false
  },
  "range_normalization": {
    "video_route": {
      "algorithm": "trim; remove one trailing d/D; JavaScript Number.parseInt base 10; non-finite or <=0 means default; action then floors and clamps",
      "default_days": 90,
      "maximum_days": 90,
      "examples": {
        "7d": 7,
        "7days": 7,
        "+12D": 12,
        "0": 90,
        "-1": 90,
        "garbage": 90,
        "999": 90
      }
    },
    "dashboard": {
      "accepted": ["24h", "7d", "30d", "lifetime"],
      "default": "7d",
      "buckets": {"24h": "hour", "7d": "day", "30d": "day", "lifetime": "day"},
      "lifetime_fallback_days": 30
    }
  },
  "tracking": {
    "session": "trim then truncate to 128 UTF-16 code units; empty or exact anonymous becomes null",
    "sanitized_strings": "trim; exact unknown becomes absent; truncate to 256 UTF-16 code units",
    "user_agent_precedence": ["user-agent header", "body.userAgent", "unknown"],
    "user_agent_parser": "ua-parser-js@1.0.41; executor must prove exact parser parity from raw_user_agent before release",
    "timestamp": "body.occurredAt parsed by Date then toISOString, otherwise request time",
    "city": "decodeURIComponent with original value on decode failure, then sanitize",
    "hostname_precedence": ["body.hostname", "request hostname", "empty"],
    "pathname_default": "/s/{videoId}",
    "skip": ["viewer_is_owner", "any_video_upload_row", "video_updated_less_than_120000ms_ago"],
    "missing_video": "still_stage_page_hit",
    "tenant_precedence": ["body.orgId", "video.ownerId", "body.ownerId", "domain:{hostname}", "public"],
    "new_video_cutoff_iso": "2026-03-04T00:00:00Z",
    "event_failure": "fail_closed",
    "email_and_notification_failure": "provider executor records a terminal receipt; never claim success from insertion",
    "anonymous_notification": {
      "requires_session": true,
      "deduplication_key": "anon_view:{videoId}:{sha256(sessionId)}",
      "rate_limit": "50 per recipient+video per rolling five minutes",
      "name": "first eight SHA-256 hex digits modulo 32 over pinned animal list"
    },
    "first_view_email": "one durable claim per video; respects pauseViews/pauseAnonViews"
  },
  "dashboard": {
    "requested_organization_must_equal_active": true,
    "space_and_video_scope_failures": "not_found",
    "d1_series": ["caps", "comments", "reactions"],
    "provider_series": ["views", "breakdowns", "top_caps"],
    "provider_failure": "fail_closed_without_partial_counts",
    "clickhouse_literal_escape_order": ["backslash", "single_quote"],
    "normalizer_order": {
      "operating_system": ["mac", "windows", "linux", "android", "ios", "ubuntu", "fedora"],
      "browser": ["chrome_not_chromium", "firefox", "safari", "edge", "opera", "brave", "internet_explorer"],
      "device": ["desktop", "mobile", "tablet"]
    }
  },
  "rpc": {
    "maximum_video_ids": 50,
    "concurrency": 10,
    "authorization": "per_item_can_view",
    "failure_shape": "per_item_not_found_exit_without_cross_item_disclosure",
    "provider_query": "group authorized videos by organization; aggregate then raw fallback over 90 days"
  },
  "signup": {
    "eligibility_days_inclusive": 7,
    "claim": "Atomic conditional UPDATE with JSON_SET; the preference value is the durable CAS claim",
    "preference_path": "$.trackedEvents.user_signed_up",
    "anonymous": false,
    "already_tracked": false,
