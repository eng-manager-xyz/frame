+async fn frame_host_guard(request: Request<Body>, next: Next) -> Response {
+    let host = request
+        .headers()
+        .get(header::HOST)
+        .and_then(|value| value.to_str().ok())
+        .unwrap_or_default();
+    if is_frame_production_host(host) {
+        StatusCode::MISDIRECTED_REQUEST.into_response()
+    } else {
+        next.run(request).await
+    }
+}
