+/// Validated, root-only origin used by every static link to Frame.
+///
+/// Production needs no configuration. Preview and local processes may set
+/// `FRAME_ORIGIN`; insecure HTTP is accepted only for an exact loopback host.
+#[derive(Clone, Debug, Eq, PartialEq)]
+pub struct FrameOrigin(reqwest::Url);
+
+impl FrameOrigin {
+    pub fn parse(raw: &str) -> Result<Self, String> {
+        if raw.is_empty()
+            || raw
+                .chars()
+                .any(|character| character.is_whitespace() || character.is_control())
+        {
+            return Err("must not be empty or contain whitespace/control characters".to_string());
+        }
+
+        let authority = raw
+            .split_once("://")
+            .map(|(_, remainder)| remainder)
+            .and_then(|remainder| remainder.split(['/', '?', '#']).next())
+            .unwrap_or_default();
+        if authority.contains('@') {
+            return Err("must not contain credentials".to_string());
+        }
+
+        let parsed = reqwest::Url::parse(raw)
+            .map_err(|error| format!("must be an absolute URL: {error}"))?;
+        let host = parsed
+            .host_str()
+            .ok_or_else(|| "must include a host".to_string())?;
+        let loopback = matches!(host, "localhost" | "127.0.0.1" | "::1");
+
+        match parsed.scheme() {
+            "https" => {}
+            "http" if loopback => {}
+            "http" => return Err("HTTP is allowed only for an exact loopback host".to_string()),
+            _ => return Err("scheme must be HTTPS, or HTTP for loopback development".to_string()),
+        }
+        if !parsed.username().is_empty() || parsed.password().is_some() {
+            return Err("must not contain credentials".to_string());
+        }
+        if parsed.path() != "/" || parsed.query().is_some() || parsed.fragment().is_some() {
+            return Err("must be an origin with only the root path".to_string());
+        }
+
+        Ok(Self(parsed))
+    }
+
+    pub fn as_str(&self) -> &str {
+        self.0.as_str()
+    }
+}
+
+impl fmt::Display for FrameOrigin {
+    fn fmt(&self, formatter: &mut fmt::Formatter<'_>) -> fmt::Result {
+        formatter.write_str(self.as_str())
+    }
+}
+
+static FRAME_ORIGIN: LazyLock<FrameOrigin> = LazyLock::new(|| {
+    let configured = var(FRAME_ORIGIN_ENV_VAR).ok();
+    let raw = configured.as_deref().unwrap_or(DEFAULT_FRAME_ORIGIN);
+    FrameOrigin::parse(raw)
+        .unwrap_or_else(|error| panic!("invalid {FRAME_ORIGIN_ENV_VAR}: {error}"))
+});
+
+pub fn frame_origin() -> &'static FrameOrigin {
+    &FRAME_ORIGIN
+}
