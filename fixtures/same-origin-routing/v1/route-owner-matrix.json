  ],
  "transport_cases": [
    {
      "kind": "methods",
      "contract": "original Request method is dispatched without an edge rewrite; route-specific allowlists return 405"
    },
    {
      "kind": "query",
      "contract": "query remains on the Request while raw-path classification excludes it"
    },
    {
      "kind": "request_body",
      "contract": "bounded JSON and fixed-length upload streams are read from the original Request"
    },
    {
      "kind": "response_stream",
      "contract": "R2 response bodies are returned as streams without a gateway buffer"
    },
    {
      "kind": "range",
      "contract": "one bounded byte range yields verified 206 metadata; invalid or multi-range input yields 416"
    },
    {
      "kind": "redirect",
      "contract": "edge ownership introduces no redirect; Worker Location headers are resource locations, never user-derived redirect targets"
    },
    {
      "kind": "upgrade",
      "contract": "no API route upgrades protocols; unsupported methods or paths fail closed and never return 101"
    },
    {
      "kind": "error",
      "contract": "stable JSON errors include one normalized request ID and no-store headers"
    }
  ]
}
