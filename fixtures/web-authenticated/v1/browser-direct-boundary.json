{
  "schema": "frame.web-browser-direct-boundary.v1",
  "topology_adr": "docs/adr/0004-engmanager-render-cloudflare-topology.md",
  "render_ssr": "data-free-no-credential-forwarding",
  "authentication": {
    "methods": ["POST"],
    "paths": [
      "/api/v1/web/auth/login",
      "/api/v1/web/auth/signup",
      "/api/v1/web/auth/recovery",
      "/api/v1/web/auth/verify",
      "/api/v1/web/auth/logout"
    ],
    "origin": "exact-request-origin",
    "fetch_site": "same-origin",
    "session_cookie": "__Host-frame_session;Secure;HttpOnly;SameSite=Lax;Path=/",
    "csrf_cookie": "__Host-frame_csrf;Secure;SameSite=Strict;Path=/",
    "pending_cookie": "__Host-frame_auth_pending;Secure;HttpOnly;SameSite=Strict;Path=/",
    "secret_source": "worker-csprng",
    "delivery_sealing": "versioned-aes-256-gcm+fixed-1071-byte-ciphertext+purpose-expiry-aad",
    "delivery_handoff": "d1-ciphertext-only-deduplicated",
    "provider_execution": "protected-not-executed"
  },
  "load": {
    "method": "GET",
    "path": "/api/v1/web/workspace/{surface}",
    "credential": "__Host-frame_session",
    "tenant_source": "users.active_organization_id+organization_preference_revision; dashboard recovery exposes only current active memberships",
    "selection_contract": "opaque-context+revision+authorized-frame-uuid-choices",
    "authority_revalidation": "exact-selection-membership-before-and-after-dto",
    "cache": "invalidate-all-workspace-envelopes-after-mutation"
  },
  "mutation": {
    "method": "POST",
    "path": "/api/v1/web/actions/{action}",
    "credential": "__Host-frame_session",
    "csrf_cookie": "__Host-frame_csrf",
    "csrf_header": "x-frame-csrf",
    "origin": "exact-request-origin",
    "fetch_site": "same-origin",
    "idempotency_header": "idempotency-key",
    "uncertain_outcome": "retain-exact-request-and-key+invalidate-all+force-refresh",
    "one_use_grant": "auth_session_mutation_grants_v2",
    "atomic_operation_table": "authenticated_web_action_operations_v1",
    "applied_http_status": 200,
    "pending_protected_execution_http_status": 202,
    "atomic_authority_assertions": [
      "action-specific organization-or-selection revision",
      "current active-organization selection",
      "current source-or-target membership",
      "one_use_mutation_grant",
      "replay_current_authority"
    ],
    "active_organization_selector": {
      "input": "authorized-frame-uuid-choice",
      "recovery": "dashboard-membership-only-selector-when-current-selection-invalid",
      "grant_disposition": "atomic-with-selection-write-and-idempotency-receipt",
      "idempotency_scope": "user+action+key-across-target-organizations",
      "replay_authority": "receipt-target-selection-revision+target-membership+one-use-grant",
      "rate_limit_bucket": "organization_library.v1",
      "legacy_cap_server_action_status": "local-contract-ingress-pending"
    }
  },
  "forbidden_browser_headers": [
    "authorization",
    "x-frame-tenant-id"
  ],
  "actions": [
    "organization.active-selection.update.v1",
    "organization.spaces.create.v1",
    "organization.folders.create.v1",
    "organization.onboarding.complete.v1",
    "business.imports.start.v1",
    "identity.account.update.v1",
    "organization.settings.update.v1",
    "organization.members.manage.v1",
    "business.storage.configure.v1",
    "business.developer.credentials.manage.v1",
    "business.billing.manage.v1",
    "business.admin.execute.v1"
  ],
  "applied_actions": [
    "organization.active-selection.update.v1",
    "organization.spaces.create.v1",
    "organization.folders.create.v1",
    "business.imports.start.v1",
    "identity.account.update.v1",
    "organization.settings.update.v1"
  ],
  "pending_protected_execution_actions": [
    "organization.onboarding.complete.v1",
    "organization.members.manage.v1",
    "business.storage.configure.v1",
    "business.developer.credentials.manage.v1",
    "business.billing.manage.v1",
    "business.admin.execute.v1"
  ]
}
